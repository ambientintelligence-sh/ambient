{
  "name": "ambient",
  "productName": "Ambient",
  "private": true,
  "version": "1.5.2",
  "license": "AGPL-3.0-only",
  "description": "The end of work about work. Ambient listens, finds the signal, and dispatches agents in parallel while you stay in the zone.",
  "author": "Jiayi Li, Shuting Hu",
  "homepage": "https://www.ambientintelligence.sh/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ambientintelligence-sh/ambient.git"
  },
  "bugs": {
    "url": "https://github.com/ambientintelligence-sh/ambient/issues"
  },
  "main": ".vite/build/main.js",
  "scripts": {
    "dev": "electron-forge start",
    "start": "electron-forge start",
    "postinstall": "[ -n \"$CI\" ] || npx --yes @electron/rebuild -f -w better-sqlite3",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:type": "pnpm exec tsc --noEmit",
    "check:unused": "pnpm exec tsc --noEmit -p tsconfig.unused.json",
    "check:reachability": "node scripts/check-runtime-reachability.mjs",
    "check:deadcode": "pnpm run check:type && pnpm run check:unused && pnpm run check:reachability",
    "check:ci": "pnpm run check:type && pnpm test && pnpm electron:package",
    "db:reset": "rm -f \"$HOME/Library/Application Support/ambient/ambient.db\" && echo 'DB deleted.'",
    "db:seed": "pnpm rebuild better-sqlite3 --silent && tsx scripts/seed-demo.ts && npx --yes @electron/rebuild -f -w better-sqlite3",
    "db:fresh": "pnpm db:reset && pnpm db:seed",
    "electron:dev": "electron-forge start",
    "electron:package": "electron-forge package",
    "electron:make": "electron-forge make"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.63",
    "@ai-sdk/google": "^3.0.29",
    "@ai-sdk/google-vertex": "4.0.17",
    "@anthropic-ai/claude-agent-sdk": "^0.2.104",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/lora": "^5.2.8",
    "@hugeicons/core-free-icons": "^3.1.1",
    "@hugeicons/react": "^1.1.5",
    "@icons-pack/react-simple-icons": "^13.12.0",
    "@mariozechner/pi-agent-core": "^0.67.68",
    "@mariozechner/pi-ai": "^0.67.68",
    "@mariozechner/pi-coding-agent": "^0.67.68",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@openai/codex-sdk": "^0.114.0",
    "@openrouter/ai-sdk-provider": "^2.2.3",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@rive-app/react-webgl2": "^4.27.0",
    "@sinclair/typebox": "^0.34.49",
    "@streamdown/cjk": "^1.0.2",
    "@streamdown/code": "^1.0.2",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@xyflow/react": "^12.10.0",
    "ai": "^6.0.86",
    "ansi-to-react": "^6.2.6",
    "audiotee": "^0.0.7",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.1",
    "embla-carousel-react": "^8.6.0",
    "exa-js": "^2.4.0",
    "lucide-react": "^0.564.0",
    "macos-audio-devices": "^1.4.0",
    "media-chrome": "^4.17.2",
    "motion": "^12.34.0",
    "nanoid": "^5.1.6",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-jsx-parser": "^2.4.1",
    "secure-exec": "^0.2.1",
    "shadcn": "^3.8.5",
    "shiki": "^3.22.0",
    "streamdown": "^2.2.0",
    "tailwind-merge": "^3.4.1",
    "tokenlens": "^1.3.1",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.3",
    "usehooks-ts": "^3.1.1",
    "zod": "^4.3.5",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-dmg": "^7.6.0",
    "@electron-forge/maker-zip": "^7.6.0",
    "@electron-forge/plugin-vite": "^7.6.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.0.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "electron": "^34.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "fs-xattr",
      "macos-alias"
    ]
  }
}
