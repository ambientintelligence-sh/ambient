# Copy this file to `.env` and fill in values for the providers you want to use.
# Only OPENROUTER_API_KEY is required for the default configuration.

# --- Required (default provider) ---
# OpenRouter API key — used for transcription + analysis via Gemini Flash.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# --- Optional: alternative LLM providers ---
# Use Google AI (Gemini) directly instead of routing through OpenRouter.
GEMINI_API_KEY=
# Alternative env name supported by @ai-sdk/google.
GOOGLE_GENERATIVE_AI_API_KEY=

# --- Optional: agent tools ---
# Exa API key — enables web search for AI agents.
# Get one at https://exa.ai
EXA_API_KEY=

# --- Optional: feature toggles ---
# Set to "false" to disable the built-in Notion/Linear MCP connectors.
MCP_INTEGRATIONS_ENABLED=true
